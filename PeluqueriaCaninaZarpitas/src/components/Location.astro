---
const { data } = Astro.props;
---

<section id="ubicacion" class="py-16 sm:py-24 bg-zinc-900 relative">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 sm:gap-12 lg:gap-24 items-start">

			<!-- Información -->
			<div class="reveal order-2 lg:order-1">
				<h2 class="text-brand-green-600 font-semibold tracking-wide uppercase text-xs sm:text-sm mb-3">Dónde encontrarnos</h2>
				<h3 class="text-3xl sm:text-4xl md:text-5xl font-playfair font-bold text-white mb-4 sm:mb-6">Visítanos en {data.city.split(',')[0]}</h3>
				<p class="text-base sm:text-lg text-white mb-6 sm:mb-8">
					Estamos en una zona accesible con facilidad de aparcamiento para que traer a tu mascota sea lo más cómodo posible.
				</p>

				<div class="space-y-5 sm:space-y-6">
					<!-- Dirección -->
					<div class="flex items-start">
						<div class="flex-shrink-0 w-10 h-10 sm:w-12 sm:h-12 bg-brand-purple-50 text-brand-purple-500 rounded-xl sm:rounded-2xl flex items-center justify-center">
							<svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
						</div>
						<div class="ml-3 sm:ml-4">
							<h4 class="text-sm sm:text-base font-bold text-white">Dirección</h4>
							<p class="mt-1 text-sm sm:text-base text-white">{data.address}</p>
							<a href={data.mapLinkUrl} target="_blank" rel="noopener noreferrer" class="inline-block mt-2 text-xs sm:text-sm text-brand-purple-500 font-medium hover:text-brand-purple-600">Cómo llegar &rarr;</a>
						</div>
					</div>

					<!-- Horario -->
					<div class="flex items-start">
						<div class="flex-shrink-0 w-10 h-10 sm:w-12 sm:h-12 bg-brand-purple-50 text-brand-purple-500 rounded-xl sm:rounded-2xl flex items-center justify-center">
							<svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
						</div>
						<div class="ml-3 sm:ml-4">
							<h4 class="text-sm sm:text-base font-bold text-white">Horario</h4>
							<p class="mt-1 text-sm sm:text-base text-white">
								{data.schedule.split('|').map((line) => (
									<span class="block">{line.trim()}</span>
								))}
							</p>
						</div>
					</div>

					<!-- Teléfono -->
					<div class="flex items-start">
						<div class="flex-shrink-0 w-10 h-10 sm:w-12 sm:h-12 bg-brand-purple-50 text-brand-purple-500 rounded-xl sm:rounded-2xl flex items-center justify-center">
							<svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
						</div>
						<div class="ml-3 sm:ml-4">
							<h4 class="text-sm sm:text-base font-bold text-white">Contacto</h4>
							<a href={`tel:+${data.phoneClean}`} class="mt-1 block text-sm sm:text-base text-white hover:text-brand-purple-500 transition-colors">{data.phone}</a>
							<a href={`https://wa.me/${data.phoneClean}`} target="_blank" rel="noopener noreferrer" class="inline-block mt-2 text-xs sm:text-sm text-brand-purple-500 font-medium hover:text-brand-purple-600">Escribir por WhatsApp &rarr;</a>
						</div>
					</div>
				</div>
			</div>

			<!-- Mapa -->
			<div class="relative h-72 sm:h-96 lg:h-[500px] rounded-2xl sm:rounded-3xl overflow-hidden shadow-lg border border-zinc-700 reveal order-1 lg:order-2" style="transition-delay: 200ms;">
				<iframe
					src={data.mapEmbedUrl}
					width="100%"
					height="100%"
					style="border:0;"
					allowfullscreen=""
					loading="lazy"
					referrerpolicy="no-referrer-when-downgrade"
					title={`Ubicación de ${data.name} en Google Maps`}
					class="grayscale-[0.2] contrast-[1.05] brightness-[1.05]"
				></iframe>
			</div>

		</div>
	</div>
</section>

