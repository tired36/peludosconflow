---
import { SITE_DATA } from '../pages/index.astro';

const products = [
	{
		title: "Pienso Super Premium",
		category: "Alimentación",
		description: "Alimentos de alta calidad para todas las razas y edades. Sin cereales y con alto porcentaje de carne fresca.",
		image: "https://images.unsplash.com/photo-1589924691995-400dc9ecc119?auto=format&fit=crop&q=80",
		badge: "Recomendado"
	},
	{
		title: "Snacks Naturales",
		category: "Premios",
		description: "Snacks deshidratados 100% naturales. Perfectos para el adiestramiento y la salud dental.",
		image: "https://images.unsplash.com/photo-1623341214825-9f4f963727da?auto=format&fit=crop&q=80",
		badge: ""
	},
	{
		title: "Champús y Cosmética",
		category: "Higiene",
		description: "La misma cosmética profesional que usamos en peluquería, disponible para cuidar a tu mascota en casa.",
		image: "https://images.unsplash.com/photo-1583337130417-3346a1be7dee?auto=format&fit=crop&q=80",
		badge: "Novedad"
	},
	{
		title: "Accesorios y Juguetes",
		category: "Accesorios",
		description: "Arneses ergonómicos, correas resistentes y juguetes seguros para su estimulación mental.",
		image: "https://images.unsplash.com/photo-1576201836106-db1758fd1c97?auto=format&fit=crop&q=80",
		badge: ""
	}
];
---

<section id="tienda" class="py-16 sm:py-24 bg-stone-50 border-t border-stone-200">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

		<div class="mb-10 sm:mb-16 reveal">
			<h2 class="text-brand-green-600 font-semibold tracking-wide uppercase text-xs sm:text-sm mb-3">Nuestra Tienda</h2>
			<h3 class="text-3xl sm:text-4xl md:text-5xl font-playfair font-bold text-stone-900 mb-4 sm:mb-6">Alimentación y Accesorios</h3>
			<p class="text-base sm:text-lg text-stone-600 max-w-2xl">
				Todo lo que tu mascota necesita para estar sana y feliz. Te asesoramos sobre el mejor pienso y accesorios adaptados a su raza.
			</p>
			<div class="mt-4 sm:mt-6">
				<span class="inline-flex items-center text-xs sm:text-sm font-medium text-brand-purple-800 bg-brand-purple-100 px-3 sm:px-4 py-1.5 rounded-full">
					<svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 mr-1.5 sm:mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
					Compra en tienda
				</span>
			</div>
		</div>

		<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5 sm:gap-6 mb-8">
			{products.map((product, index) => (
				<div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-stone-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group reveal" style={`transition-delay: ${index * 80}ms;`}>
					<div class="relative h-44 sm:h-48 overflow-hidden">
						<div class="absolute top-2 left-2 bg-black/50 text-white text-[9px] sm:text-[10px] font-medium px-2 py-0.5 rounded shadow-sm z-20">
							Foto de muestra
						</div>
						<img src={product.image} alt={product.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
						{product.badge && (
							<div class="absolute top-2 right-2 bg-brand-purple-500 text-white text-[10px] sm:text-xs font-bold px-2.5 py-0.5 rounded-full shadow-md z-20">
								{product.badge}
							</div>
						)}
					</div>
					<div class="p-4 sm:p-6">
						<div class="text-[10px] sm:text-xs font-bold text-brand-green-600 uppercase tracking-wider mb-1 sm:mb-2">{product.category}</div>
						<h4 class="text-base sm:text-xl font-bold text-stone-900 mb-1 sm:mb-2">{product.title}</h4>
						<p class="text-stone-600 text-xs sm:text-sm mb-4 sm:mb-6 line-clamp-3">{product.description}</p>
						<a
							href={`https://wa.me/${SITE_DATA.phoneClean}?text=Hola, me interesa el producto: ${product.title}`}
							target="_blank"
							rel="noopener noreferrer"
							class="w-full inline-flex justify-center items-center px-4 py-2 border border-brand-purple-500 text-brand-purple-600 hover:bg-brand-purple-500 hover:text-white rounded-full font-medium transition-colors text-xs sm:text-sm"
						>
							<svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 mr-1.5 sm:mr-2" fill="currentColor" viewBox="0 0 24 24">
								<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
							</svg>
							Consultar stock
						</a>
					</div>
				</div>
			))}
		</div>

		<!-- Nota informativa -->
		<div class="rounded-2xl border border-brand-purple-100 bg-brand-purple-50 p-4 sm:p-6 flex gap-3 sm:gap-4 items-start reveal">
			<div class="flex-shrink-0 w-9 h-9 sm:w-10 sm:h-10 bg-brand-purple-100 rounded-xl flex items-center justify-center text-brand-purple-600">
				<svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
			</div>
			<div>
				<p class="text-xs sm:text-sm font-bold text-brand-purple-900 mb-1">Esto es solo una muestra de cómo quedaría la tienda online</p>
				<p class="text-xs sm:text-sm text-brand-purple-700 leading-relaxed">
					Se pueden añadir todos los productos organizados por categorías: Alimentación, Premios, Higiene, Accesorios... Cada producto puede tener descripción, foto real e incluso precio. Consultalo conmigo para ampliarla cuando quieras.
				</p>
			</div>
		</div>
	</div>
</section>
