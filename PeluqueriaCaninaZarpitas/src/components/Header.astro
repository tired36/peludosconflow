---
const { data } = Astro.props;
---

<!-- Banner provisional -->
<div class="w-full text-white text-[11px] font-medium text-center py-2 px-3 flex items-center justify-center gap-1.5 z-[60] relative leading-tight bg-brand-purple-500">
	<svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
	<span>Web provisional · Modelo de demo. No es la web real. Diseño totalmente personalizable.</span>
</div>

<header class="sticky top-0 w-full z-50 transition-all duration-300 bg-white/95 backdrop-blur-md shadow-sm" id="main-header">
	<div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
		<div class="flex justify-between items-center h-16 md:h-20">

			<!-- Logo oficial Zarpitas -->
			<div class="flex-shrink-0 flex items-center">
				<a href="#inicio" class="flex items-center gap-2.5 sm:gap-3">
					<img
						src="/iconopeludosconflow.png"
						alt="Logo Zarpitas Albolote"
						class="h-10 w-10 sm:h-12 sm:w-12 object-contain"
					/>
					<div class="flex flex-col leading-tight">
						<span class="font-playfair font-bold text-base sm:text-xl text-stone-800">Zarpitas</span>
						<span class="text-[9px] sm:text-[10px] font-semibold uppercase tracking-wider text-brand-green-500">Tienda y Peluquería Canina</span>
					</div>
				</a>
			</div>

			<!-- Desktop Menu -->
			<nav class="hidden lg:flex space-x-6 xl:space-x-8">
				<a href="#inicio" class="text-stone-600 hover:text-brand-purple-500 font-medium transition-colors text-sm xl:text-base">Inicio</a>
				<a href="#servicios" class="text-stone-600 hover:text-brand-purple-500 font-medium transition-colors text-sm xl:text-base">Servicios</a>
				<a href="#tienda" class="text-stone-600 hover:text-brand-purple-500 font-medium transition-colors text-sm xl:text-base">Tienda</a>
				<a href="#transformaciones" class="text-stone-600 hover:text-brand-purple-500 font-medium transition-colors text-sm xl:text-base">Galería</a>
				<a href="#opiniones" class="text-stone-600 hover:text-brand-purple-500 font-medium transition-colors text-sm xl:text-base">Opiniones</a>
				<a href="#ubicacion" class="text-stone-600 hover:text-brand-purple-500 font-medium transition-colors text-sm xl:text-base">Ubicación</a>
			</nav>

			<!-- CTA + Redes (desktop) -->
			<div class="hidden lg:flex items-center gap-3">
				<a href={data.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-9 h-9 flex items-center justify-center rounded-full text-stone-500 hover:text-brand-purple-500 hover:bg-brand-purple-50 transition-colors">
					<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" /></svg>
				</a>
				<a href={data.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-9 h-9 flex items-center justify-center rounded-full text-stone-500 hover:text-brand-purple-500 hover:bg-brand-purple-50 transition-colors">
					<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" /></svg>
				</a>
				<div class="w-px h-5 bg-stone-200"></div>
				<a href={`https://wa.me/${data.phoneClean}?text=${encodeURIComponent(data.whatsappMessage)}`} target="_blank" rel="noopener noreferrer" class="text-white px-5 py-2 rounded-full font-medium transition-colors shadow-md hover:opacity-90 text-sm bg-brand-purple-500 hover:bg-brand-purple-600">
					Pedir cita
				</a>
			</div>

			<!-- Mobile: WhatsApp + hamburguesa -->
			<div class="lg:hidden flex items-center gap-2">
				<a href={`https://wa.me/${data.phoneClean}?text=${encodeURIComponent(data.whatsappMessage)}`} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="w-9 h-9 flex items-center justify-center rounded-full bg-brand-green-500 hover:bg-brand-green-600 text-white shadow transition-colors">
					<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
				</a>
				<button id="mobile-menu-btn" class="w-9 h-9 flex items-center justify-center rounded-full text-stone-600 hover:text-brand-purple-500 focus:outline-none transition-colors" aria-label="Abrir menú">
					<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
					</svg>
				</button>
			</div>
		</div>
	</div>

	<!-- Mobile Menu -->
	<div id="mobile-menu" class="lg:hidden absolute w-full bg-white border-t border-stone-100 shadow-xl transition-all duration-300 origin-top scale-y-0 opacity-0 pointer-events-none">
		<div class="px-4 pt-2 pb-5 space-y-0.5">
			<a href="#inicio" class="block px-3 py-3 text-base font-medium text-stone-700 rounded-lg transition-colors hover:text-brand-purple-500 hover:bg-brand-purple-50">Inicio</a>
			<a href="#servicios" class="block px-3 py-3 text-base font-medium text-stone-700 rounded-lg transition-colors hover:text-brand-purple-500 hover:bg-brand-purple-50">Servicios</a>
			<a href="#tienda" class="block px-3 py-3 text-base font-medium text-stone-700 rounded-lg transition-colors hover:text-brand-purple-500 hover:bg-brand-purple-50">Tienda</a>
			<a href="#transformaciones" class="block px-3 py-3 text-base font-medium text-stone-700 rounded-lg transition-colors hover:text-brand-purple-500 hover:bg-brand-purple-50">Galería</a>
			<a href="#opiniones" class="block px-3 py-3 text-base font-medium text-stone-700 rounded-lg transition-colors hover:text-brand-purple-500 hover:bg-brand-purple-50">Opiniones</a>
			<a href="#ubicacion" class="block px-3 py-3 text-base font-medium text-stone-700 rounded-lg transition-colors hover:text-brand-purple-500 hover:bg-brand-purple-50">Ubicación</a>
			<div class="flex items-center gap-4 px-3 pt-3 pb-1 border-t border-stone-100 mt-2">
				<a href={data.social.instagram} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-stone-500 hover:text-brand-purple-500 transition-colors">
					<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" /></svg>
					Instagram
				</a>
				<a href={data.social.facebook} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-stone-500 hover:text-brand-purple-500 transition-colors">
					<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" /></svg>
					Facebook
				</a>
			</div>
			<div class="px-3 pt-2 pb-1">
				<a href={`https://wa.me/${data.phoneClean}?text=${encodeURIComponent(data.whatsappMessage)}`} target="_blank" rel="noopener noreferrer" class="block w-full text-center text-white px-5 py-3 rounded-xl font-medium shadow-md text-sm bg-brand-purple-500 hover:bg-brand-purple-600 transition-colors">
					Pedir cita por WhatsApp
				</a>
			</div>
		</div>
	</div>
</header>

<script>
	const btn = document.getElementById('mobile-menu-btn');
	const menu = document.getElementById('mobile-menu');
	const links = menu?.querySelectorAll('a');
	let isMenuOpen = false;

	const closeMenu = () => {
		isMenuOpen = false;
		menu?.classList.remove('scale-y-100', 'opacity-100');
		menu?.classList.add('scale-y-0', 'opacity-0', 'pointer-events-none');
	};

	const openMenu = () => {
		isMenuOpen = true;
		menu?.classList.remove('scale-y-0', 'opacity-0', 'pointer-events-none');
		menu?.classList.add('scale-y-100', 'opacity-100');
	};

	btn?.addEventListener('click', () => isMenuOpen ? closeMenu() : openMenu());
	links?.forEach(link => link.addEventListener('click', closeMenu));
</script>
