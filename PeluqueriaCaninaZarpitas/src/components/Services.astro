---
const services = [
	{
		title: "Baño Completo",
		description: "Baño relajante con champús específicos para su tipo de piel y manto. Incluye secado profesional.",
		icon: `<svg class="w-7 h-7" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>`
	},
	{
		title: "Corte de Pelo",
		description: "Cortes a tijera o máquina adaptados a la raza y preferencias del dueño. Estilos modernos y cómodos.",
		icon: `<svg class="w-7 h-7" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>`
	},
	{
		title: "Deslanado",
		description: "Eliminación del pelo muerto para reducir la caída en casa y permitir que la piel respire mejor.",
		icon: `<svg class="w-7 h-7" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/></svg>`
	},
	{
		title: "Corte de Uñas",
		description: "Arreglo y limado de uñas para evitar molestias al caminar y prevenir problemas posturales.",
		icon: `<svg class="w-7 h-7" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 11.08c1.37-.9 3.52-.46 4.34 1.13c.69 1.34.62 3-.16 4.3c-1.3 2.1-3.66 3.49-6.18 3.49s-4.88-1.39-6.18-3.49c-.78-1.3-.85-2.96-.16-4.3c.82-1.59 2.97-2.03 4.34-1.13c1.02.66 2.37.66 3.4 0z"/><circle cx="5.5" cy="8.5" r="2.5"/><circle cx="10" cy="4" r="2.5"/><circle cx="15.5" cy="5" r="2.5"/><circle cx="19" cy="10" r="2.5"/></svg>`
	},
	{
		title: "Limpieza de Oídos",
		description: "Limpieza profunda pero delicada para prevenir infecciones y mantener una buena higiene auditiva.",
		icon: `<svg class="w-7 h-7" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M7 5H3"/></svg>`
	},
	{
		title: "Ozonoterapia",
		description: "Baños de ozono para pieles sensibles. Reduce el picor, el olor y mantiene el pelo brillante durante semanas.",
		icon: `<svg class="w-7 h-7" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><ellipse cx="12" cy="12" rx="11" ry="4"/><ellipse cx="12" cy="12" rx="11" ry="4" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="11" ry="4" transform="rotate(120 12 12)"/></svg>`
	}
];
---

<section id="servicios" class="py-16 sm:py-24 bg-zinc-900">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center max-w-3xl mx-auto mb-10 sm:mb-16 reveal">
			<h2 class="text-brand-green-600 font-semibold tracking-wide uppercase text-xs sm:text-sm mb-3">Lo que hacemos</h2>
			<h3 class="text-3xl sm:text-4xl md:text-5xl font-playfair font-bold text-white mb-4 sm:mb-6">Nuestros Servicios</h3>
			<p class="text-base sm:text-lg text-white">
				Ofrecemos un cuidado integral para tu mascota, asegurando que luzca espectacular y se sienta genial.
			</p>
		</div>

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-8">
			{services.map((service, index) => (
				<div class="bg-zinc-950 rounded-2xl p-6 sm:p-8 border border-zinc-800 hover:border-brand-purple-400 transition-all duration-300 group reveal card-hover" style={`transition-delay: ${index * 80}ms;`}>
					<div class="w-14 h-14 bg-zinc-900 rounded-xl shadow-sm flex items-center justify-center text-brand-purple-500 mb-5 group-hover:bg-brand-purple-500 group-hover:text-white transition-all duration-300">
						<Fragment set:html={service.icon} />
					</div>
					<h4 class="text-lg sm:text-xl font-bold text-white mb-2 sm:mb-3">{service.title}</h4>
					<p class="text-sm sm:text-base text-white leading-relaxed">{service.description}</p>
				</div>
			))}
		</div>
	</div>
</section>

