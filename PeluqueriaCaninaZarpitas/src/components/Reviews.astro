---
const reviews = [
	{
		name: "luz dary rico rodríguez",
		text: "Fenomenal me encantó la atención y amabilidad de José, atendió a mi Lara como si fuera suya. Repetiré las veces que le haga falta a mí perrilla.",
		rating: 5,
		date: "Hace 3 meses"
	},
	{
		name: "Rocío Ferrer Fernández",
		text: "Lleve a mis perritos allí, y salieron con 3 años menos del cambio de look tan precioso que le hicieron. Me encanta todo un profesional José , repetiremos el mes que viene!!!",
		rating: 5,
		date: "Hace 3 meses"
	},
	{
		name: "Isabel Benítez",
		text: "Peluqueria canina recomedada 100% Son unos auténticos profesionales! Además tienen un montón de variedad de productos para perros y chuches naturales, a Triana le encantan!!",
		rating: 5,
		date: "Hace 3 meses"
	},
	{
		name: "Irma Layola monforte",
		text: "Lleve a mis perritas allí,el trato fue increíble, sheila la dueña es un primor, jose el peluquero otro primor. Maravilloso trato por parte de ambos...",
		rating: 5,
		date: "Hace 3 meses"
	},
	{
		name: "Vaiven",
		text: "Trato increíble, Jose todo un primor y un profesional de los pies a la cabeza, tienen un montón de cosas para los perritos y para gatos yo me dejo allí el sueldo cada vez que voy...",
		rating: 5,
		date: "Hace 3 meses"
	},
	{
		name: "Loris Vallejo",
		text: "Muy buena peluquería canina. Las dos chicas que trabajan ahí son muy buenas profesionales, simpáticas y tienen un buen trato con los animales. Muy recomendable.",
		rating: 5,
		date: "Hace 3 semanas"
	}
];

const StarIcon = `<svg class="w-4 h-4 sm:w-5 sm:h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>`;
---

<section id="opiniones" class="py-16 sm:py-24 bg-zinc-950 border-y border-zinc-700">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center max-w-3xl mx-auto mb-10 sm:mb-16 reveal">
			<h2 class="text-brand-green-600 font-semibold tracking-wide uppercase text-xs sm:text-sm mb-3">Qué opinan nuestros clientes</h2>
			<h3 class="text-3xl sm:text-4xl md:text-5xl font-playfair font-bold text-white mb-5 sm:mb-6">Reseñas destacadas de Google</h3>
			<div class="flex items-center justify-center gap-2 mb-2">
				<span class="text-2xl sm:text-3xl font-bold text-white">4.3</span>
				<div class="flex">
					<Fragment set:html={StarIcon} />
					<Fragment set:html={StarIcon} />
					<Fragment set:html={StarIcon} />
					<Fragment set:html={StarIcon} />
					<svg class="w-4 h-4 sm:w-5 sm:h-5 text-stone-300" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
				</div>
			</div>
			<p class="text-zinc-400 text-xs sm:text-sm">Basado en 23 opiniones reales</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-5 sm:gap-8 mb-8 sm:mb-12">
			{reviews.map((review, index) => (
				<div class="bg-zinc-900 p-5 sm:p-8 rounded-2xl shadow-sm border border-zinc-800 reveal" style={`transition-delay: ${index * 100}ms;`}>
					<div class="flex items-center mb-3 sm:mb-4">
						<div class="w-10 h-10 sm:w-12 sm:h-12 bg-brand-purple-100 text-brand-purple-800 rounded-full flex items-center justify-center font-bold text-lg sm:text-xl mr-3 sm:mr-4 flex-shrink-0">
							{review.name.charAt(0)}
						</div>
						<div>
							<h4 class="font-bold text-white text-sm sm:text-base">{review.name}</h4>
							<p class="text-xs text-zinc-400">{review.date}</p>
						</div>
					</div>
					<div class="flex mb-3 sm:mb-4">
						{Array.from({ length: review.rating }).map(() => (
							<Fragment set:html={StarIcon} />
						))}
					</div>
					<p class="text-zinc-300 italic text-sm sm:text-base leading-relaxed">"{review.text}"</p>
				</div>
			))}
		</div>

		<div class="text-center reveal">
			<a href="https://maps.app.goo.gl/ppD3QJEXWTvk1y6k7" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-brand-purple-500 font-semibold hover:text-brand-purple-600 transition-colors text-sm sm:text-base">
				<svg class="w-4 h-4 sm:w-5 sm:h-5 mr-2" viewBox="0 0 24 24"><path fill="currentColor" d="M21.35,11.1H12.18V13.83H18.69C18.36,17.64 15.19,19.27 12.19,19.27C8.36,19.27 5,16.25 5,12C5,7.9 8.2,4.73 12.2,4.73C15.29,4.73 17.1,6.7 17.1,6.7L19,4.72C19,4.72 16.56,2 12.1,2C6.42,2 2.03,6.8 2.03,12C2.03,17.05 6.16,22 12.25,22C17.6,22 21.5,18.33 21.5,12.91C21.5,11.76 21.35,11.1 21.35,11.1V11.1Z" /></svg>
				Ver más reseñas en Google Maps
				<svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
			</a>
		</div>
	</div>
</section>

