---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Store from '../components/Store.astro';
import Transformations from '../components/Transformations.astro';
import About from '../components/About.astro';
import Reviews from '../components/Reviews.astro';
import Location from '../components/Location.astro';
import Footer from '../components/Footer.astro';

// ==========================================
// VARIABLES DE CONFIGURACIÓN DEL NEGOCIO
// Cambia estos valores para actualizar toda la web
// ==========================================
export const SITE_DATA = {
	name: "Peludos con flow",
	city: "Maracena", 
	phone: "603 18 46 26",
	phoneClean: "34603184626", // Para el enlace de llamada y WhatsApp
	whatsappMessage: "Hola, me gustaría pedir una cita para mi mascota o consultar un producto.",
	address: "Calle Pedro Arroyo, Maracena",
	email: "",
	schedule: "Lun, Mar, Mié, Jue, Vie: 9:00-13:30 y 17:00-20:30 | Sáb: 10:00-13:30 | Dom: Cerrado",
	mapEmbedUrl: "https://maps.google.com/maps?q=Calle%20Pedro%20Arroyo,%2018200,%20Maracena,%20Espa%C3%B1a&t=&z=16&ie=UTF8&iwloc=&output=embed",
	mapLinkUrl: "https://maps.app.goo.gl/ppD3QJEXWTvk1y6k7",
	social: {
		instagram: "https://www.instagram.com/peludosconflowmaracena/",
		facebook: "https://www.facebook.com/groups/1741679096128543/posts/3754859054810527/"
	}
};

const pageTitle = `Tienda & Peluquería Canina en ${SITE_DATA.city} | ${SITE_DATA.name}`;
const pageDescription = `Peludos con flow – Peluquería canina y tienda de mascotas en ${SITE_DATA.city} (Granada). Baño, corte, deslanado, comida premium y accesorios. ¡Pide cita por WhatsApp! 📞 ${SITE_DATA.phone}`;

// Schema JSON-LD para SEO Local
const schema = {
	"@context": "https://schema.org",
	"@type": "PetStore",
	"name": SITE_DATA.name,
	"image": "https://images.unsplash.com/photo-1516734212186-a967f81ad0d7?auto=format&fit=crop&q=80",
	"@id": "",
	"url": "https://www.tusitioweb.com",
	"telephone": SITE_DATA.phone,
	"address": {
		"@type": "PostalAddress",
		"streetAddress": "Calle Pedro Arroyo",
		"addressLocality": "Maracena",
		"addressRegion": "Granada",
		"postalCode": "18200",
		"addressCountry": "ES"
	},
	"geo": {
		"@type": "GeoCoordinates",
		"latitude": 37.2076,
		"longitude": -3.6339
	},
	"openingHoursSpecification": [
		{
			"@type": "OpeningHoursSpecification",
			"dayOfWeek": [
				"Monday",
				"Tuesday",
				"Wednesday",
				"Thursday",
				"Friday"
			],
			"opens": "09:00",
			"closes": "13:30"
		},
		{
			"@type": "OpeningHoursSpecification",
			"dayOfWeek": [
				"Monday",
				"Tuesday",
				"Wednesday",
				"Thursday",
				"Friday"
			],
			"opens": "17:00",
			"closes": "20:30"
		},
		{
			"@type": "OpeningHoursSpecification",
			"dayOfWeek": "Saturday",
			"opens": "10:00",
			"closes": "13:30"
		}
	]
};
---

<Layout title={pageTitle} description={pageDescription}>
	<!-- Schema Markup -->
	<script type="application/ld+json" set:html={JSON.stringify(schema)} />

	<Header data={SITE_DATA} />
	
	<main>
		<Hero data={SITE_DATA} />
		<Services />
		<Store />
		<Transformations />
		<About />
		<Reviews />
		<Location data={SITE_DATA} />
		
		<!-- CTA Final -->
		<section class="py-24 bg-zinc-900 border-t border-zinc-800 text-white relative overflow-hidden">
			<div class="absolute inset-0 opacity-10">
				<svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none">
					<path d="M0,0 L100,100 L0,100 Z" fill="currentColor"></path>
				</svg>
			</div>
			<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10 reveal">
				<h2 class="text-4xl md:text-5xl font-playfair font-bold mb-6 text-glow">¿Tu mascota necesita un cambio?</h2>
				<p class="text-xl text-white mb-10 max-w-2xl mx-auto drop-shadow">
					Reserva su cita hoy mismo y dale el cuidado profesional que se merece. ¡Saldrá moviendo la cola!
				</p>
				<a 
					href={`https://wa.me/${SITE_DATA.phoneClean}?text=${encodeURIComponent(SITE_DATA.whatsappMessage)}`}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-full text-zinc-900 bg-zinc-800 hover:bg-zinc-200 hover:text-zinc-950 transition-all duration-300 shadow-[0_0_15px_rgba(255,255,255,0.4)] hover:shadow-[0_0_25px_rgba(255,255,255,0.6)] transform hover:-translate-y-1 animate-bounce-slow"
				>
					<svg class="w-6 h-6 mr-2 text-green-600" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
					</svg>
					Pedir cita por WhatsApp
				</a>
			</div>
		</section>
	</main>
	
	<Footer data={SITE_DATA} />
</Layout>
