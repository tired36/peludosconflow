---
const { data } = Astro.props;
---

<section id="inicio" class="relative min-h-screen flex items-center overflow-hidden">

	<!-- Fondo: imagen de muestra -->
	<div class="absolute inset-0 z-0">
		<img
			src="https://images.unsplash.com/photo-1591769225440-811ad7d6eab3?auto=format&fit=crop&q=80&w=1600"
			alt="Peluquería canina de fondo"
			class="w-full h-full object-cover brightness-75"
		/>
	</div>

	<!-- Gradiente oscuro -->
	<div class="absolute inset-0 z-10 bg-gradient-to-r from-black/70 via-black/45 to-black/20"></div>

	<!-- Contenido -->
	<div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 w-full">
		<div class="max-w-2xl reveal">

			<!-- Badge superior -->
			<div class="inline-flex items-center px-4 py-2 rounded-full bg-white/20 backdrop-blur-md text-white font-bold text-xs sm:text-sm mb-6 sm:mb-8 border border-white/50 shadow-[0_0_15px_rgba(255,255,255,0.3)] hover:scale-105 transition-transform">
				<span class="flex h-2.5 w-2.5 rounded-full bg-brand-green-400 mr-2 animate-pulse flex-shrink-0"></span>
				Tienda & Peluquería Canina · {data.city}
			</div>

			<!-- Título -->
			<h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-playfair font-bold text-white text-glow leading-tight mb-4 sm:mb-6">
				El mejor cuidado para tu mascota en
				<span class="text-white text-glow-accent animate-pulse inline-block">
					{data.city.split(',')[0]}
				</span>
			</h1>

			<!-- Subtítulo -->
			<p class="text-lg sm:text-2xl text-white font-medium mb-8 sm:mb-10 max-w-xl leading-relaxed drop-shadow-lg text-glow-accent">
				Peluquería profesional y tienda especializada en alimentación y accesorios para mascotas. Trato cercano y personalizado.
			</p>

			<!-- Botones CTA -->
			<div class="flex flex-col sm:flex-row gap-3 sm:gap-4 mb-10 sm:mb-16">
				<a
					href={`https://wa.me/${data.phoneClean}?text=${encodeURIComponent(data.whatsappMessage)}`}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex justify-center items-center px-6 sm:px-8 py-3.5 sm:py-4 text-sm sm:text-base font-semibold rounded-full text-white transition-all duration-300 shadow-lg shadow-brand-purple-900/40 bg-brand-purple-500 hover:bg-brand-purple-600"
				>
					<svg class="w-4 h-4 sm:w-5 sm:h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
						<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
					</svg>
					Pedir cita por WhatsApp
				</a>
				<a
					href="#servicios"
					class="inline-flex justify-center items-center px-6 sm:px-8 py-3.5 sm:py-4 text-sm sm:text-base font-semibold rounded-full text-white bg-zinc-900/10 hover:bg-zinc-900/20 border border-white/30 backdrop-blur-sm transition-all duration-300"
				>
					Ver servicios
				</a>
			</div>

			<!-- Badges de confianza -->
			<div class="flex flex-wrap gap-2 sm:gap-4 mt-8">
				<div class="flex items-center gap-1.5 sm:gap-2 text-xs sm:text-sm text-white font-semibold bg-white/20 backdrop-blur-md px-4 py-2 rounded-full border border-white/40 shadow-lg hover:-translate-y-1 transition-transform">
					<svg class="w-4 h-4 text-yellow-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
					4.3 en Google · 23 reseñas
				</div>
				<div class="flex items-center gap-1.5 sm:gap-2 text-xs sm:text-sm text-white font-semibold bg-white/20 backdrop-blur-md px-4 py-2 rounded-full border border-white/40 shadow-lg hover:-translate-y-1 transition-transform">
					<svg class="w-4 h-4 text-brand-green-400 flex-shrink-0 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
					Trato cercano
				</div>
				<div class="flex items-center gap-1.5 sm:gap-2 text-xs sm:text-sm text-white font-semibold bg-white/20 backdrop-blur-md px-4 py-2 rounded-full border border-white/40 shadow-lg hover:-translate-y-1 transition-transform">
					<svg class="w-4 h-4 text-brand-green-400 flex-shrink-0 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
					Tienda especializada
				</div>
			</div>
		</div>
	</div>

	<!-- Flecha scroll -->
	<div class="absolute bottom-6 sm:bottom-8 left-1/2 -translate-x-1/2 z-20 animate-bounce">
		<a href="#servicios" class="flex flex-col items-center text-white/50 hover:text-white/80 transition-colors">
			<span class="text-[10px] sm:text-xs mb-1 sm:mb-2 uppercase tracking-widest">Ver más</span>
			<svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
		</a>
	</div>
</section>

